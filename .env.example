# Copy to .env and fill in real values. .env is gitignored — never commit secrets.

# Groq API key for the generator LLM (src/agent/). Get one at https://console.groq.com/keys
GROQ_API_KEY=

# Redis connection — defaults match configs/config.yaml agent.memory.redis_url.
# Local dev: `brew install redis && brew services start redis` (no Docker required).
REDIS_URL=redis://localhost:6379/0
