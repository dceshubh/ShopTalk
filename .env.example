# Copy to .env and fill in real values. .env is gitignored — never commit secrets.

# Groq API key for the generator LLM (src/agent/). Get one at https://console.groq.com/keys
GROQ_API_KEY=

# Redis connection — overrides configs/config.yaml agent.memory.redis_url when set
# (src.agent.memory.load_persistent_memory). For local dev, leave this line COMMENTED OUT —
# the config.yaml default (redis://localhost:6379/0) is correct once you've run
# `brew install redis && brew services start redis` (no Docker required).
#
# `docker compose up` sets this for you (REDIS_URL=redis://redis:6379/0 — Redis is reachable
# by *service name* inside compose's network, not "localhost"); compose's `environment:`
# always wins over this file's `env_file:` value for the same key, so you don't need to
# touch this for compose either. Only set it here for a bare `docker run` / EC2 deployment
# that ISN'T going through docker-compose, where you control the address directly:
# REDIS_URL=redis://<your-redis-host>:6379/0

# API base URL the Streamlit UI calls — overrides configs/config.yaml ui.api_base_url when
# set (src.ui.app._config). Same story as REDIS_URL: leave COMMENTED OUT for local dev
# (localhost:8000 is correct) and for `docker compose up` (it sets API_BASE_URL=http://api:8000
# itself, and its `environment:` wins over this file). Only needed for a bare `docker run`
# UI container that must reach the API by some other address:
# API_BASE_URL=http://<your-api-host>:8000
